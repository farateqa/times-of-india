  function dumpAudsToLocalStorage() {
    if(typeof localStorage != "undefined" && typeof colaud != "undefined" && colaud.aud != ""){
      localStorage.setItem('colaud', colaud.aud);
    }
  }
  
  // Use GDPR callback to conditionally load script - by default not loaded
  if (window.TimesGDPR && window.TimesGDPR.common && window.TimesGDPR.common.consentModule && window.TimesGDPR.common.consentModule.gdprCallback) {
    window.TimesGDPR.common.consentModule.gdprCallback(function(dataObj) {
      if (dataObj.isEUuser === false) {
        // Only load script for non-EU users
        ccaudjs();
      }
    });
